<%- include('includes/header') %>

<link rel="stylesheet" type="text/css" href="/css/products.css" />

<body>
  <div class="products-container">
    <div class="navigation-menu">
      <ul class="nav justify-content-center">
        <li class="nav-item" style="cursor: pointer">
          <a class="nav-link active" href="/admin/">Home</a>
        </li>
        <li class="nav-item" style="cursor: pointer">
          <a class="nav-link" href="/admin/course/all">Courses</a>
        </li>
        <li class="nav-item" style="cursor: pointer">
          <a class="nav-link" href="/admin/user/all">Users</a>
        </li>
        <li
          class="nav-item"
          style="cursor: pointer"
          onclick="return confirm('Do you want to logout?')"
        >
          <a class="nav-link" href="/admin/logout">Logout</a>
        </li>
      </ul>
    </div>

    <div class="restaurant-menu-frame">
      <div class="board">
        <div class="dishes-table">
          <span class="new-dish-txt" style="margin-bottom: 30px">
            COURSES LIST
          </span>
          <table class="table table-bordered table-hover">
            <thead class="thead-light">
              <tr class="thead-light">
                <th scope="col">T/r</th>
                <th scope="col">Course Name</th>
                <th scope="col">Course Category</th>
                <th scope="col">Course Price</th>
                <th scope="col">Course Type</th>
                <th scope="col">Available Slots  </th>
                <th scope="col">Status</th>
              </tr>
            </thead>
            <!--  LOOP PRODUCTS: START  -->
            <% products.map(function(value, key) { %>
            <tbody style="background: white">
              <td><%= key +1 %></td>
              <td><%= value.courseName %></td>
              <td><%= value.CourseCollection %></td>
              <td><%= value.coursePrice %></td>
              <td><%= value.courseType %></td>
              <td><%= value.courseLeftCount %></td>
              <td>
                <select class="spec-select new-product-status" id="<%= value._id %>">
                  <option value="PAUSE" <%= value.courseStatus === 'PAUSE' ? 'selected' : '' %>>PAUSE</option>
                  <option value="PROCESS" <%= value.courseStatus === 'PROCESS' ? 'selected' : '' %>>PROCESS</option>
                  <option value="DELETE" <%= value.courseStatus === 'DELETE' ? 'selected' : '' %>>DELETE</option>
                </select>
              </td>
            </tbody>
            <% }) %>
            
            <!--  LOOP PRODUCTS: END  -->
          </table>
          <div
            class="long-input"
            style="align-items: flex-end; margin-bottom: 25px"
          >
            <button class="btn btn-primary" id="process-btn">
              New Course
            </button>
          </div>
        </div>
        <form
          onsubmit="return validForm()"
          action="/admin/course/create"
          method="POST"
          class="dish-container"
          enctype="multipart/form-data"
        >
          <div class="long-input" style="display: flex; align-items: center">
            <span class="new-dish-txt">NEW COURSE DETAIL</span>
          </div>
          <div class="login-input-frame">
            <div class="long-input">
              <label>Course Name</label>
              <input
                type="text"
                placeholder="Name"
                name="courseName"
                class="product-name"
              />
            </div>
            <input
              name="courseStatus"
              value="PAUSE"
              class="product-status"
              hidden
            />
          </div>
          <div class="half-input-frame">
            <div class="half-input">
              <label>Course Price</label>
              <input
                type="number"
                placeholder="Price"
                name="coursePrice"
                class="product-price"
              />
            </div>
            <div class="half-input">
              <label>Course Left Counts</label>
              <input
                type="number"
                placeholder="Counts"
                name="courseLeftCount"
                class="product-left-count"
              />
            </div>
          </div>
          <div class="half-input-frame">
            <div class="half-input">
              <label>Course Category</label>
              <select class="product-collection" name="CourseCollection">
                <option value="IT" selected>IT</option>
                <option value="LANGUAGE">LANGUAGE</option>
                <option value="FINANCE">FINANCE</option>
                <option value="MATH">MATH</option>
                <option value="SCIENCE">SCIENCE</option>
                <option value="OTHER">Other</option>
              </select>
            </div>

            <div class="half-input" id="product-collection">
              <label>Course Type</label>
              <select class="product-size" name="courseType">
                <option value="BASIC">BASIC</option>
                <option value="STANDARD" selected>STANDARD</option>
                <option value="PREMIUM">PREMIUM</option>
                <option value="PLATINUM">PLATINUM</option>
              </select>
            </div>

            <div class="half-input" id="product-volume" style="display: none">
              <label>Course Volume</label>
              <select class="product-volume" name="courseVolume">
                <option value="0.5">30 minutes</option>
                <option value="1" selected>1 hour</option>
                <option value="1.5" selected>1,5 hours</option>
                <option value="2">2 hours</option>
                <option value="2.5">2,5 hours</option>
              </select>
            </div>
          </div>
          <div class="long-input">
            <label>Course Description</label>
            <textarea name="courseDesc" class="product-desc"></textarea>
          </div>

          <div class="img-frame">
            <label>Course Images</label>
            <div class="media-frame">
              <div class="upload-img-box">
                <img src="/img/uplds.png" class="1" id="image-section-1" />
                <input
                  type="file"
                  id="file"
                  name="courseImages"
                  class="image-one"
                  required
                  onchange="previewFileHandler(this, 1)"
                />
              </div>
              <div class="upload-img-box">
                <img src="/img/uplds.png" class="2" id="image-section-2" />
                <input
                  type="file"
                  id="file"
                  name="courseImages"
                  class="image-two"
                  onchange="previewFileHandler(this, 2)"
                />
              </div>
              <div class="upload-img-box">
                <img src="/img/uplds.png" class="3" id="image-section-3" />
                <input
                  type="file"
                  id="file"
                  name="courseImages"
                  class="image-three"
                  onchange="previewFileHandler(this, 3)"
                />
              </div>
              <div class="upload-img-box">
                <img src="/img/uplds.png" class="4" id="image-section-4" />
                <input
                  type="file"
                  id="file"
                  name="courseImages"
                  class="image-four"
                  onchange="previewFileHandler(this, 4)"
                />
              </div>
              <div class="upload-img-box">
                <img src="/img/uplds.png" class="5" id="image-section-5" />
                <input
                  type="file"
                  id="file"
                  name="courseImages"
                  class="image-five"
                  onchange="previewFileHandler(this, 5)"
                />
              </div>
              <input name="adminId" class="restaurant-id" hidden />
            </div>
          </div>

          <div class="operation-buttons">
            <button class="btn btn-danger" id="cancel-btn">Cancel</button>
            <button type="submit" class="btn btn-primary" id="create-btn">
              Create
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script type="text/javascript" src="/js/courses.js"></script>
</body>

<%- include('includes/footer') %>
